generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum AttendanceStatus {
  CHECKED_IN
  CHECKED_OUT
}

enum VerificationLevel {
  VERIFIED
  REVIEW
  REJECTED
}

model User {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  emailVerified Boolean            @default(false)
  image         String?
  role          Role               @default(USER)
  attendance    AttendanceRecord[]
  qrSessions    DynamicQRSession[] @relation("QrIssuer")
  sessions      Session[]
  accounts      Account[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Site {
  id             String             @id @default(cuid())
  name           String
  latitude       Float
  longitude      Float
  allowedRadiusM Int                @default(120)
  isActive       Boolean            @default(true)
  attendance     AttendanceRecord[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([isActive])
}

model AttendanceRecord {
  id                String              @id @default(cuid())
  userId            String
  siteId            String?
  status            AttendanceStatus    @default(CHECKED_IN)
  checkedInAt       DateTime
  checkedOutAt      DateTime?
  workedMinutes     Int?
  checkInLat        Float?
  checkInLng        Float?
  checkOutLat       Float?
  checkOutLng       Float?
  verificationLevel VerificationLevel @default(REVIEW)
  confidenceScore   Int               @default(0)
  plannedTasks      String?
  completedTasks    String?
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  site              Site?               @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([userId, checkedInAt])
  @@index([siteId])
}

model DynamicQRSession {
  id          String    @id @default(cuid())
  createdById String
  tokenHash   String    @unique
  nonce       String    @unique
  issuedAt    DateTime
  expiresAt   DateTime
  usedAt      DateTime?
  createdBy   User      @relation("QrIssuer", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier, expiresAt])
}
